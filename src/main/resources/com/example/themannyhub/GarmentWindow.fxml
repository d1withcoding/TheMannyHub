<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.themannyhub.controllers.GarmentWindowController">

    <top>
        <VBox spacing="12" style="-fx-padding: 15; -fx-border-color: -color-border-default; -fx-border-width: 0 0 1 0;">
            <Label fx:id="titleLabel" text="Garments"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Filter by Type:" style="-fx-min-width: 100; -fx-font-size: 12px;"/>
                <ComboBox fx:id="typeFilterComboBox" prefWidth="180" onAction="#onTypeFilterChange"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="garmentTable" style="-fx-padding: 10;">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="50"/>
                <TableColumn fx:id="typeColumn" text="Type" prefWidth="90"/>
                <TableColumn fx:id="summaryColumn" text="Measurements" prefWidth="420"/>
                <TableColumn fx:id="notesColumn" text="Notes" prefWidth="180"/>
                <TableColumn fx:id="modifiedColumn" text="Last Modified" prefWidth="140"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <HBox spacing="10" alignment="CENTER_LEFT"
              style="-fx-padding: 12 15 12 15; -fx-border-color: -color-border-default; -fx-border-width: 1 0 0 0;">
            <Button fx:id="addButton" text="Add Garment" prefWidth="130"
                    onAction="#onAddGarmentClick"
                    style="-fx-background-color: -color-accent-emphasis; -fx-text-fill: white;"/>
            <Button fx:id="editButton" text="Edit" prefWidth="80"
                    onAction="#onEditGarmentClick" disable="true"/>
            <Button fx:id="deleteButton" text="Delete" prefWidth="80"
                    onAction="#onDeleteGarmentClick" disable="true"
                    style="-fx-background-color: -color-danger-emphasis; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusLabel" text="Ready"
                   style="-fx-text-fill: -color-fg-subtle;"/>
        </HBox>
    </bottom>
</BorderPane>