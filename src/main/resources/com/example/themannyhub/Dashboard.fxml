<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.themannyhub.controllers.DashboardController"
            style="-fx-background-color: -color-bg-subtle;">

    <!-- ===================================================================
         TOP HEADER BAR
         =================================================================== -->
    <top>
        <HBox style="-fx-padding: 12 20 12 20; -fx-border-color: -color-border-default; -fx-border-width: 0 0 1 0;">
            <Label text="The Manny Hub"
                   style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="userLabel"
                   style="-fx-text-fill: -color-fg-subtle; -fx-font-size: 12px; -fx-padding: 0 15 0 0;"/>
            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: -color-danger-emphasis; -fx-text-fill: white;
                           -fx-font-size: 11px; -fx-padding: 5 14 5 14;"/>
        </HBox>
    </top>

    <!-- ===================================================================
         LEFT SIDEBAR
         =================================================================== -->
    <left>
        <VBox style="-fx-background-color: -color-bg-subtle; -fx-border-color: -color-border-default;
                     -fx-border-width: 0 1 0 0; -fx-padding: 15 0 15 0;"
              prefWidth="200" spacing="3">

            <VBox spacing="3" style="-fx-padding: 0 8 0 8;">
                <Label text="NAVIGATION"
                       style="-fx-font-size: 10px; -fx-font-weight: bold;
                              -fx-text-fill: -color-fg-subtle; -fx-padding: 0 0 6 8;"/>

                <Button fx:id="dashboardNavBtn" text="Dashboard"
                        style="-fx-background-color: -color-accent-emphasis; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-padding: 9 14 9 14; -fx-background-radius: 6;
                               -fx-alignment: CENTER_LEFT;"
                        onAction="#onDashboardNavClick"/>

                <Button fx:id="customersNavBtn" text="Customers"
                        style="-fx-background-color: transparent; -fx-font-size: 13px;
                               -fx-padding: 9 14 9 14; -fx-background-radius: 6;
                               -fx-alignment: CENTER_LEFT;"
                        onAction="#onCustomersNavClick"/>

                <Button fx:id="garmentsNavBtn" text="Garments"
                        style="-fx-background-color: transparent; -fx-font-size: 13px;
                               -fx-padding: 9 14 9 14; -fx-background-radius: 6;
                               -fx-alignment: CENTER_LEFT;"
                        onAction="#onGarmentsNavClick"/>
            </VBox>

            <Separator style="-fx-padding: 10 0 0 0;"/>

            <VBox spacing="3" style="-fx-padding: 10 8 0 8;">
                <Label text="QUICK ACTIONS"
                       style="-fx-font-size: 10px; -fx-font-weight: bold;
                              -fx-text-fill: -color-fg-subtle; -fx-padding: 0 0 6 8;"/>

                <Button text="New Customer" maxWidth="Infinity"
                        style="-fx-background-color: -color-accent-emphasis; -fx-text-fill: white;
                               -fx-font-size: 12px; -fx-padding: 8 14 8 14; -fx-background-radius: 6;"
                        onAction="#addNewCustomer"/>

                <Button text="New Garment" maxWidth="Infinity"
                        style="-fx-background-color: -color-success-emphasis; -fx-text-fill: white;
                               -fx-font-size: 12px; -fx-padding: 8 14 8 14; -fx-background-radius: 6;"
                        onAction="#addNewGarment"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>

    <!-- ===================================================================
         CENTER CONTENT AREA (views swap here)
         =================================================================== -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: -color-bg-default;">
            <!-- Dashboard home view is loaded here by default -->
        </StackPane>
    </center>

    <!-- ===================================================================
         MODAL OVERLAY (hidden by default, shown for dialogs)
         =================================================================== -->
    <bottom>
        <StackPane fx:id="modalOverlay" visible="false" managed="false"
                   style="-fx-background-color: rgba(0,0,0,0.4);"
                   StackPane.alignment="CENTER">
            <!-- Modal content injected here programmatically -->
        </StackPane>
    </bottom>
</BorderPane>