<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.themannyhub.controllers.DashboardController"
            stylesheets="@css/application.css"
            style="-fx-background-color: #F8FAFC;">

    <!-- ===================================================================
         LEFT SIDEBAR
         =================================================================== -->
    <left>
        <VBox styleClass="sidebar" prefWidth="260">

            <!-- Logo -->
            <Label text="The Manny Hub"
                   style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #111827;
                          -fx-padding: 0 24 24 24;"/>

            <!-- Navigation -->
            <VBox styleClass="sidebar-nav" VBox.vgrow="ALWAYS">
                <Label text="Menu" styleClass="sidebar-section-title"/>

                <Button fx:id="dashboardNavBtn" text="Dashboard"
                        styleClass="sidebar-button, sidebar-button-active"
                        onAction="#onDashboardNavClick"/>

                <Button fx:id="customersNavBtn" text="Customers"
                        styleClass="sidebar-button"
                        onAction="#onCustomersNavClick"/>

                <Button fx:id="garmentsNavBtn" text="Garments"
                        styleClass="sidebar-button"
                        onAction="#onGarmentsNavClick"/>
            </VBox>

            <!-- Bottom: User + Logout -->
            <VBox style="-fx-padding: 16 12 0 12; -fx-spacing: 8;">
                <Separator styleClass="divider"/>
                <Label fx:id="userLabel"
                       style="-fx-font-size: 13px; -fx-text-fill: #6B7280; -fx-padding: 8 12 0 12;"/>
                <Button text="Logout" onAction="#handleLogout"
                        styleClass="sidebar-button"
                        style="-fx-text-fill: #EF4444;"/>
            </VBox>
        </VBox>
    </left>

    <!-- ===================================================================
         CENTER CONTENT
         =================================================================== -->
    <center>
        <StackPane fx:id="contentArea"
                   style="-fx-background-color: #F8FAFC; -fx-padding: 32;"/>
    </center>
</BorderPane>