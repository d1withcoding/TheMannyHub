<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21.0.6"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.themannyhub.controllers.DashboardController"
      style="-fx-background-color: #f0f2f5;">

    <padding>
        <Insets top="0" right="0" bottom="0" left="0"/>
    </padding>

    <!-- Header Bar -->
    <HBox style="-fx-background-color: #1a2332; -fx-padding: 20 30 20 30;">
        <Label text="The Manny Hub"
               style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <VBox alignment="CENTER_RIGHT" spacing="8">
            <Label fx:id="userLabel"
                   style="-fx-text-fill: #b0bec5; -fx-font-size: 13px;"/>
            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-size: 12px;
                           -fx-padding: 6 20 6 20; -fx-background-radius: 3; -fx-cursor: hand;"/>
        </VBox>
    </HBox>

    <!-- Main Content Area -->
    <VBox spacing="25" style="-fx-padding: 30 40 30 40;" VBox.vgrow="ALWAYS">

        <!-- Quick Search Section -->
        <VBox spacing="10">
            <Label text="QUICK SEARCH"
                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #7f8c8d;
                          -fx-letter-spacing: 1px;"/>
            <HBox spacing="10">
                <TextField fx:id="searchField" promptText="Search customers by name or phone number..."
                           style="-fx-font-size: 15px; -fx-padding: 12 15 12 15;
                                  -fx-background-radius: 5; -fx-border-radius: 5;
                                  -fx-border-color: #d5d8dc; -fx-border-width: 1;
                                  -fx-background-color: white;"
                           HBox.hgrow="ALWAYS"/>
            </HBox>
            <!-- Search Results Dropdown (hidden by default) -->
            <VBox fx:id="searchResultsBox" visible="false" managed="false"
                  style="-fx-background-color: white; -fx-border-color: #d5d8dc; -fx-border-width: 1;
                         -fx-border-radius: 0 0 5 5; -fx-background-radius: 0 0 5 5;
                         -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 8, 0, 0, 3);"/>
        </VBox>

        <!-- Recent Customers and Quick Actions -->
        <HBox spacing="25" VBox.vgrow="ALWAYS">

            <!-- Recent Customers Panel -->
            <VBox spacing="15" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 8;
                         -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 4);">

                <HBox>
                    <Label text="RECENT CUSTOMERS"
                           style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #7f8c8d;
                                  -fx-letter-spacing: 1px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>

                <Separator style="-fx-background-color: #ecf0f1;"/>

                <VBox fx:id="recentCustomersList" spacing="8" VBox.vgrow="ALWAYS">
                    <!-- Recent customers will be dynamically added here -->
                    <Label text="No recent customers yet"
                           style="-fx-text-fill: #95a5a6; -fx-font-size: 14px; -fx-padding: 20 0 0 0;"/>
                </VBox>
            </VBox>

            <!-- Quick Actions Panel -->
            <VBox spacing="15" prefWidth="280"
                  style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 8;
                         -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 4);">

                <Label text="QUICK ACTIONS"
                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #7f8c8d;
                              -fx-letter-spacing: 1px;"/>

                <Separator style="-fx-background-color: #ecf0f1;"/>

                <!-- Primary Action Buttons -->
                <Button text="New Customer" maxWidth="Infinity" onAction="#addNewCustomer"
                        style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-size: 14px;
                               -fx-font-weight: bold; -fx-padding: 14; -fx-background-radius: 5;
                               -fx-cursor: hand;"/>

                <Button text="New Garment" maxWidth="Infinity" onAction="#addNewGarment"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14px;
                               -fx-font-weight: bold; -fx-padding: 14; -fx-background-radius: 5;
                               -fx-cursor: hand;"/>

                <Separator style="-fx-background-color: #ecf0f1; -fx-padding: 5 0 0 0;"/>

                <Label text="NAVIGATION"
                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #7f8c8d;
                              -fx-letter-spacing: 1px; -fx-padding: 5 0 0 0;"/>

                <!-- Navigation Links -->
                <Button text="Customer Management" maxWidth="Infinity" onAction="#openCustomerManagement"
                        style="-fx-background-color: transparent; -fx-text-fill: #2c3e50;
                               -fx-font-size: 14px; -fx-padding: 12; -fx-background-radius: 5;
                               -fx-border-color: #bdc3c7; -fx-border-width: 1; -fx-border-radius: 5;
                               -fx-cursor: hand;"/>

                <Button text="Garment Management" maxWidth="Infinity" onAction="#openGarmentManagement"
                        style="-fx-background-color: transparent; -fx-text-fill: #2c3e50;
                               -fx-font-size: 14px; -fx-padding: 12; -fx-background-radius: 5;
                               -fx-border-color: #bdc3c7; -fx-border-width: 1; -fx-border-radius: 5;
                               -fx-cursor: hand;"/>
            </VBox>
        </HBox>
    </VBox>
</VBox>