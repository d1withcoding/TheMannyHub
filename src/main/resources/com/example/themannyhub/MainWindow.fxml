<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.themannyhub.controllers.MainWindowController"
            stylesheets="@css/application.css"
            style="-fx-background-color: #F8FAFC;">

    <!-- Header -->
    <top>
        <HBox styleClass="header" spacing="16">
            <Label text="Customers" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="searchTextField" promptText="Search customers..."
                       styleClass="input-field" prefWidth="300"
                       onKeyReleased="#onSearchTextChange"/>
            <ComboBox fx:id="statusFilterComboBox" prefWidth="150"
                      styleClass="input-field"
                      style="-fx-min-height: 48; -fx-padding: 0 16 0 16;"
                      onAction="#onStatusFilterChange"/>
            <Button text="Add Customer" styleClass="btn-primary"
                    onAction="#onAddCustomerClick"/>
        </HBox>
    </top>

    <!-- Table -->
    <center>
        <VBox style="-fx-padding: 0 32 0 32;" VBox.vgrow="ALWAYS">
            <TableView fx:id="customerTable" styleClass="modern-table"
                       VBox.vgrow="ALWAYS"
                       style="-fx-background-radius: 16; -fx-background-color: white;">
                <columns>
                    <TableColumn fx:id="idColumn" text="#" prefWidth="40" sortable="false"
                                 style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="nameColumn" text="Name" prefWidth="140"/>
                    <TableColumn fx:id="phoneColumn" text="Phone" prefWidth="120"/>
                    <TableColumn fx:id="waistColumn" text="Waist" prefWidth="70"/>
                    <TableColumn fx:id="inseamColumn" text="Inseam" prefWidth="70"/>
                    <TableColumn fx:id="hipColumn" text="Hip" prefWidth="70"/>
                    <TableColumn fx:id="thighColumn" text="Thigh" prefWidth="70"/>
                    <TableColumn fx:id="frontRiseColumn" text="Front Rise" prefWidth="80"/>
                    <TableColumn fx:id="backRiseColumn" text="Back Rise" prefWidth="80"/>
                    <TableColumn fx:id="fitPreferencesColumn" text="Fit Preferences" prefWidth="140"/>
                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="80"/>
                </columns>
            </TableView>
        </VBox>
    </center>

    <!-- Bottom Bar -->
    <bottom>
        <HBox spacing="12" alignment="CENTER_LEFT"
              style="-fx-padding: 12 32 16 32; -fx-background-color: transparent;">
            <Button fx:id="editButton" text="Edit" styleClass="btn-secondary"
                    onAction="#onEditCustomerClick" disable="true"/>
            <Button fx:id="deleteButton" text="Delete" styleClass="btn-danger"
                    onAction="#onDeleteCustomerClick" disable="true"/>
            <Button fx:id="manageGarmentsButton" text="Manage Garments"
                    styleClass="btn-secondary"
                    onAction="#onManageGarmentsClick" disable="true"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusLabel" text="Ready"
                   style="-fx-font-size: 13px; -fx-text-fill: #6B7280;"/>
        </HBox>
    </bottom>
</BorderPane>