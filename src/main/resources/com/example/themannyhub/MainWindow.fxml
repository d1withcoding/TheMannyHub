<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane
        xmlns="http://javafx.com/javafx"
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="com.example.themannyhub.controllers.MainWindowController">

    <!-- ===================================================================
         LEFT SIDEBAR (Visual only - no navigation logic)
         =================================================================== -->
    <left>
        <VBox styleClass="sidebar" prefWidth="200" spacing="5"
              style="-fx-padding: 15 0 15 0; -fx-background-color: -color-bg-subtle; -fx-border-color: -color-border-default; -fx-border-width: 0 1 0 0;">

            <Label text="The Manny Hub"
                   style="-fx-font-size: 16px; -fx-font-weight: bold;
                          -fx-padding: 0 15 15 15;"/>

            <Separator/>

            <VBox spacing="3" style="-fx-padding: 10 8 0 8;">
                <Label text="NAVIGATION"
                       style="-fx-font-size: 10px; -fx-font-weight: bold;
                              -fx-text-fill: -color-fg-subtle; -fx-padding: 0 0 6 8;"/>

                <!-- These are just visual labels, not functional buttons -->
                <Label text="  Customers"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 8 12 8 12;
                              -fx-background-color: -color-accent-emphasis; -fx-text-fill: white;
                              -fx-background-radius: 6;"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>

    <!-- ===================================================================
         TOP SECTION: Header, Search, and Filter
         =================================================================== -->
    <top>
        <VBox spacing="12" style="-fx-padding: 15; -fx-border-color: -color-border-default; -fx-border-width: 0 0 1 0;">

            <Label text="Customer Management"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Search:" style="-fx-min-width: 60;"/>
                <TextField fx:id="searchTextField"
                           promptText="Type customer name..."
                           styleClass="search-field"
                           HBox.hgrow="ALWAYS"
                           onKeyReleased="#onSearchTextChange"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Status:" style="-fx-min-width: 60;"/>
                <ComboBox fx:id="statusFilterComboBox"
                          prefWidth="150"
                          onAction="#onStatusFilterChange"/>
            </HBox>
        </VBox>
    </top>

    <!-- ===================================================================
         CENTER SECTION: Customer Table
         =================================================================== -->
    <center>
        <TableView fx:id="customerTable" style="-fx-padding: 10;">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="40" sortable="false"/>
                <TableColumn fx:id="nameColumn" text="Name" prefWidth="120"/>
                <TableColumn fx:id="phoneColumn" text="Phone" prefWidth="100"/>
                <TableColumn fx:id="waistColumn" text="Waist (in)" prefWidth="80"/>
                <TableColumn fx:id="inseamColumn" text="Inseam (in)" prefWidth="80"/>
                <TableColumn fx:id="hipColumn" text="Hip (in)" prefWidth="80"/>
                <TableColumn fx:id="thighColumn" text="Thigh (in)" prefWidth="80"/>
                <TableColumn fx:id="frontRiseColumn" text="Front Rise (in)" prefWidth="90"/>
                <TableColumn fx:id="backRiseColumn" text="Back Rise (in)" prefWidth="90"/>
                <TableColumn fx:id="fitPreferencesColumn" text="Fit Preferences" prefWidth="150"/>
                <TableColumn fx:id="statusColumn" text="Status" prefWidth="80"/>
            </columns>
        </TableView>
    </center>

    <!-- ===================================================================
         BOTTOM SECTION: Action Buttons
         =================================================================== -->
    <bottom>
        <HBox spacing="10" alignment="CENTER_LEFT"
              style="-fx-padding: 12 15 12 15; -fx-border-color: -color-border-default; -fx-border-width: 1 0 0 0;">

            <Button fx:id="addButton" text="Add Customer"
                    prefWidth="130" onAction="#onAddCustomerClick"
                    style="-fx-background-color: -color-accent-emphasis; -fx-text-fill: white;"/>

            <Button fx:id="editButton" text="Edit"
                    prefWidth="80" onAction="#onEditCustomerClick" disable="true"/>

            <Button fx:id="deleteButton" text="Delete"
                    prefWidth="80" onAction="#onDeleteCustomerClick" disable="true"
                    style="-fx-background-color: -color-danger-emphasis; -fx-text-fill: white;"/>

            <Button fx:id="manageGarmentsButton" text="Manage Garments"
                    prefWidth="140" onAction="#onManageGarmentsClick" disable="true"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="statusLabel" text="Ready"
                   style="-fx-text-fill: -color-fg-subtle;"/>
        </HBox>
    </bottom>
</BorderPane>