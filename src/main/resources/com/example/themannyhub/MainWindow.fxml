<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<!--
MainWindow.fxml - The main customer management interface for The Manny Hub CRM

This file defines the layout of the main application window:
1. Top section: Title, search bar, and status filter
2. Center section: Table displaying all customers (11 columns)
3. Bottom section: Action buttons (Add, Edit, Delete)

The fx:controller attribute links this FXML to MainWindowController.java
The fx:id attributes link FXML elements to Java @FXML annotated fields
The onAction="#methodName" links button clicks to controller methods
-->

<BorderPane
        xmlns="http://javafx.com/javafx"
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="com.example.themannyhub.controllers.MainWindowController"
        style="-fx-font-family: 'Segoe UI'; -fx-font-size: 11;">

    <!-- ===================================================================
         TOP SECTION: Header, Search, and Filter
         =================================================================== -->

    <top>
        <VBox spacing="15" style="-fx-padding: 15; -fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-width: 0 0 1 0;">

            <!-- Title -->
            <Label
                    text="The Manny Hub - Customer Manager"
                    style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #333;"/>

            <!-- Search Section -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Search by Name:" style="-fx-font-weight: bold; -fx-min-width: 100;"/>
                <TextField
                        fx:id="searchTextField"
                        promptText="Type customer name..."
                        prefWidth="300"
                        onKeyReleased="#onSearchTextChange">
                    <!--
                    fx:id="searchTextField" - Java controller can access this TextField
                    promptText - Placeholder text shown when empty
                    onKeyReleased="#onSearchTextChange" - Calls onSearchTextChange() method when user types
                    Note: onKeyReleased means search updates as you type (real-time)
                    -->
                </TextField>
                <Label text="Results will update as you type" style="-fx-text-fill: #666; -fx-font-size: 10;"/>
            </HBox>

            <!-- Filter Section -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Filter by Status:" style="-fx-font-weight: bold; -fx-min-width: 100;"/>
                <ComboBox
                        fx:id="statusFilterComboBox"
                        prefWidth="150"
                        onAction="#onStatusFilterChange">
                    <!--
                    fx:id="statusFilterComboBox" - Java controller accesses this
                    onAction="#onStatusFilterChange" - Calls method when selection changes
                    Items populated by controller (All Customers, Active, Inactive)
                    -->
                </ComboBox>
            </HBox>
        </VBox>
    </top>

    <!-- ===================================================================
         CENTER SECTION: Customer Table (11 Columns)
         =================================================================== -->

    <center>
        <TableView
                fx:id="customerTable"
                prefHeight="400"
                style="-fx-padding: 10;">
            <!--
            fx:id="customerTable" - Java controller accesses this TableView
            prefHeight="400" - Initial height (will resize with window)
            The columns are defined below, each with a unique name and type
            -->

            <!-- Column 1: ID -->
            <columns>
                <TableColumn
                        text="ID"
                        prefWidth="40"
                        sortable="false">
                    <!--
                    text="ID" - Column header shown to user
                    prefWidth="40" - Initial width (can be resized by user)
                    sortable="false" - User can't sort by this column
                    cellValueFactory handled by controller via setCellValueFactory()
                    -->
                </TableColumn>

                <!-- Column 2: Name -->
                <TableColumn
                        text="Name"
                        prefWidth="120">
                    <!--
                    This column displays customer.getName()
                    Sorting enabled by default
                    -->
                </TableColumn>

                <!-- Column 3: Phone -->
                <TableColumn
                        text="Phone"
                        prefWidth="100"/>

                <!-- Column 4: Waist -->
                <TableColumn
                        text="Waist (in)"
                        prefWidth="80"/>

                <!-- Column 5: Inseam -->
                <TableColumn
                        text="Inseam (in)"
                        prefWidth="80"/>

                <!-- Column 6: Hip -->
                <TableColumn
                        text="Hip (in)"
                        prefWidth="80"/>

                <!-- Column 7: Thigh -->
                <TableColumn
                        text="Thigh (in)"
                        prefWidth="80"/>

                <!-- Column 8: Front Rise -->
                <TableColumn
                        text="Front Rise (in)"
                        prefWidth="90"/>

                <!-- Column 9: Back Rise -->
                <TableColumn
                        text="Back Rise (in)"
                        prefWidth="90"/>

                <!-- Column 10: Fit Preferences -->
                <TableColumn
                        text="Fit Preferences"
                        prefWidth="150"/>

                <!-- Column 11: Status -->
                <TableColumn
                        text="Status"
                        prefWidth="80"/>
            </columns>
            <!--
            Note: Controller will programmatically set up cellValueFactory for each column
            This links the column to the Customer object's getter methods
            Example: nameColumn.setCellValueFactory(new PropertyValueFactory<>("name"));
            -->
        </TableView>
    </center>

    <!-- ===================================================================
         BOTTOM SECTION: Action Buttons
         =================================================================== -->

    <bottom>
        <HBox
                spacing="10"
                alignment="CENTER_LEFT"
                style="-fx-padding: 15; -fx-background-color: #f9f9f9; -fx-border-color: #ddd; -fx-border-width: 1 0 0 0;">

            <!-- Add Button (always enabled) -->
            <Button
                    fx:id="addButton"
                    text="➕ Add Customer"
                    prefWidth="150"
                    onAction="#onAddCustomerClick"
                    style="-fx-font-size: 11; -fx-padding: 8;">
                <!--
                fx:id="addButton" - Reference in controller (optional here)
                text="➕ Add Customer" - Button label (emoji + text)
                onAction="#onAddCustomerClick" - Calls onAddCustomerClick() when clicked
                prefWidth="150" - Minimum width
                This button is ALWAYS enabled (user can add anytime)
                -->
            </Button>

            <!-- Edit Button (enabled only when row selected) -->
            <Button
                    fx:id="editButton"
                    text="✏️ Edit"
                    prefWidth="100"
                    onAction="#onEditCustomerClick"
                    style="-fx-font-size: 11; -fx-padding: 8;"
                    disable="true">
                <!--
                fx:id="editButton" - Controller accesses this to enable/disable
                disable="true" - Starts disabled (user must select a customer first)
                Controller will call: editButton.disableProperty().bind(...)
                to enable only when table row is selected
                -->
            </Button>

            <!-- Delete Button (enabled only when row selected) -->
            <Button
                    fx:id="deleteButton"
                    text="🗑️ Delete"
                    prefWidth="100"
                    onAction="#onDeleteCustomerClick"
                    style="-fx-font-size: 11; -fx-padding: 8; -fx-text-fill: white; -fx-base: #dc3545;"
                    disable="true">
                <!--
                fx:id="deleteButton" - Controller accesses this to enable/disable
                disable="true" - Starts disabled
                style with red color (#dc3545) to indicate danger
                -->
            </Button>

            <!-- Spacer (fills empty space, pushes buttons to left) -->
            <Region HBox.hgrow="ALWAYS"/>

            <!-- Status Label (optional, for user feedback) -->
            <Label
                    fx:id="statusLabel"
                    text="Ready"
                    style="-fx-text-fill: #666; -fx-font-size: 10;">
                <!--
                fx:id="statusLabel" - Controller can update this text
                Useful to show: "1 customer selected", "Search found 3 results", etc.
                -->
            </Label>
        </HBox>
    </bottom>

</BorderPane>