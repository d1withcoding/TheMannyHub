<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.themannyhub.controllers.CustomerDialogController"
      spacing="15"
      style="-fx-padding: 20;">

    <Label fx:id="dialogTitle" text="Add Customer"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <GridPane hgap="12" vgap="10">

        <!-- Name -->
        <Label text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="0"
               style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
        <TextField fx:id="nameField" promptText="Customer full name"
                   prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="0"
                   onKeyReleased="#onNameFieldChanged"/>
        <Label fx:id="nameErrorLabel" text="" textFill="#FF3B30" style="-fx-font-size: 10px;"
               GridPane.columnIndex="1" GridPane.rowIndex="1" visible="false" managed="false"/>

        <!-- Phone -->
        <Label text="Phone:" GridPane.columnIndex="0" GridPane.rowIndex="3"
               style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
        <TextField fx:id="phoneField" promptText="10-digit phone number"
                   prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="3"
                   onKeyReleased="#onPhoneFieldChanged"/>
        <Label fx:id="phoneErrorLabel" text="" textFill="#FF3B30" style="-fx-font-size: 10px;"
               GridPane.columnIndex="1" GridPane.rowIndex="4" visible="false" managed="false"/>

        <!-- Waist -->
        <Label text="Waist (in):" GridPane.columnIndex="0" GridPane.rowIndex="6"
               style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
        <TextField fx:id="waistField" promptText="24-50"
                   prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="6"
                   onKeyReleased="#onWaistFieldChanged"/>
        <Label fx:id="waistErrorLabel" text="" textFill="#FF3B30" style="-fx-font-size: 10px;"
               GridPane.columnIndex="1" GridPane.rowIndex="7" visible="false" managed="false"/>

        <!-- Inseam -->
        <Label text="Inseam (in):" GridPane.columnIndex="0" GridPane.rowIndex="9"
               style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
        <TextField fx:id="inseamField" promptText="26-38"
                   prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="9"
                   onKeyReleased="#onInseamFieldChanged"/>
        <Label fx:id="inseamErrorLabel" text="" textFill="#FF3B30" style="-fx-font-size: 10px;"
               GridPane.columnIndex="1" GridPane.rowIndex="10" visible="false" managed="false"/>

        <!-- Hip -->
        <Label text="Hip (in):" GridPane.columnIndex="0" GridPane.rowIndex="12"
               style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
        <TextField fx:id="hipField" promptText="30-60"
                   prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="12"
                   onKeyReleased="#onHipFieldChanged"/>
        <Label fx:id="hipErrorLabel" text="" textFill="#FF3B30" style="-fx-font-size: 10px;"
               GridPane.columnIndex="1" GridPane.rowIndex="13" visible="false" managed="false"/>

        <!-- Thigh -->
        <Label text="Thigh (in):" GridPane.columnIndex="0" GridPane.rowIndex="15"
               style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
        <TextField fx:id="thighField" promptText="18-30"
                   prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="15"
                   onKeyReleased="#onThighFieldChanged"/>
        <Label fx:id="thighErrorLabel" text="" textFill="#FF3B30" style="-fx-font-size: 10px;"
               GridPane.columnIndex="1" GridPane.rowIndex="16" visible="false" managed="false"/>

        <!-- Front Rise -->
        <Label text="Front Rise (in):" GridPane.columnIndex="0" GridPane.rowIndex="18"
               style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
        <TextField fx:id="frontRiseField" promptText="8-14"
                   prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="18"
                   onKeyReleased="#onFrontRiseFieldChanged"/>
        <Label fx:id="frontRiseErrorLabel" text="" textFill="#FF3B30" style="-fx-font-size: 10px;"
               GridPane.columnIndex="1" GridPane.rowIndex="19" visible="false" managed="false"/>

        <!-- Back Rise -->
        <Label text="Back Rise (in):" GridPane.columnIndex="0" GridPane.rowIndex="21"
               style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
        <TextField fx:id="backRiseField" promptText="8-14"
                   prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="21"
                   onKeyReleased="#onBackRiseFieldChanged"/>
        <Label fx:id="backRiseErrorLabel" text="" textFill="#FF3B30" style="-fx-font-size: 10px;"
               GridPane.columnIndex="1" GridPane.rowIndex="22" visible="false" managed="false"/>

        <!-- Fit Preferences -->
        <Label text="Fit Preferences:" GridPane.columnIndex="0" GridPane.rowIndex="24"
               style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-alignment: TOP_LEFT;"/>
        <TextArea fx:id="fitPreferencesArea" promptText="e.g., Prefers slim fit"
                  prefRowCount="3" prefWidth="300" wrapText="true"
                  GridPane.columnIndex="1" GridPane.rowIndex="24"
                  onKeyReleased="#onFitPreferencesFieldChanged"/>
        <Label fx:id="fitPreferencesErrorLabel" text="" textFill="#FF3B30" style="-fx-font-size: 10px;"
               GridPane.columnIndex="1" GridPane.rowIndex="25" visible="false" managed="false"/>

        <!-- Status -->
        <Label text="Status:" GridPane.columnIndex="0" GridPane.rowIndex="27"
               style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
        <ComboBox fx:id="statusComboBox" prefWidth="300"
                  GridPane.columnIndex="1" GridPane.rowIndex="27"
                  onAction="#onStatusSelectionChanged"/>
        <Label fx:id="statusErrorLabel" text="" textFill="#FF3B30" style="-fx-font-size: 10px;"
               GridPane.columnIndex="1" GridPane.rowIndex="28" visible="false" managed="false"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT"
          style="-fx-padding: 10 0 0 0; -fx-border-color: -color-border-default; -fx-border-width: 1 0 0 0;">
        <Button fx:id="saveButton" text="Save" prefWidth="100" onAction="#onSaveClick"
                style="-fx-background-color: -color-accent-emphasis; -fx-text-fill: white;"/>
        <Button fx:id="cancelButton" text="Cancel" prefWidth="100" onAction="#onCancelClick"/>
    </HBox>
</VBox>