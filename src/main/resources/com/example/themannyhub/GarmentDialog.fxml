<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.themannyhub.controllers.GarmentDialogController"
      spacing="12"
      style="-fx-padding: 18;">

    <Label fx:id="dialogTitle" text="Add Garment"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Garment Type:" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-min-width: 110;"/>
        <ComboBox fx:id="typeComboBox" prefWidth="200" onAction="#onTypeChanged"/>
    </HBox>

    <TabPane fx:id="typeTabPane" tabClosingPolicy="UNAVAILABLE">

        <!-- TROUSERS -->
        <Tab fx:id="trousersTab" text="Trousers">
            <GridPane hgap="10" vgap="8" style="-fx-padding: 10;">
                <Label text="Waist (in):" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="trouserWaistField" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <Label text="Inseam (in):" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="trouserInseamField" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                <Label text="Hip (in):" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="trouserHipField" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                <Label text="Thigh (in):" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="trouserThighField" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                <Label text="Front Rise (in):" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="trouserFrontRiseField" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                <Label text="Back Rise (in):" GridPane.columnIndex="0" GridPane.rowIndex="5" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="trouserBackRiseField" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                <Label text="Fit Preferences:" GridPane.columnIndex="0" GridPane.rowIndex="6" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-alignment: TOP_LEFT;"/>
                <TextArea fx:id="trouserFitPreferencesArea" prefRowCount="2" wrapText="true"
                          GridPane.columnIndex="1" GridPane.rowIndex="6"/>
            </GridPane>
        </Tab>

        <!-- SHIRT -->
        <Tab fx:id="shirtTab" text="Shirt">
            <GridPane hgap="10" vgap="8" style="-fx-padding: 10;">
                <Label text="Chest (in):" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="shirtChestField" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <Label text="Shoulder (in):" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="shirtShoulderField" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                <Label text="Sleeve (in):" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="shirtSleeveField" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                <Label text="Neck (in):" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="shirtNeckField" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                <Label text="Shirt Length (in):" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="shirtLengthField" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                <Label text="Sleeve Style:" GridPane.columnIndex="0" GridPane.rowIndex="5" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <ComboBox fx:id="shirtSleeveStyleCombo" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                <Label text="Collar Style:" GridPane.columnIndex="0" GridPane.rowIndex="6" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <ComboBox fx:id="shirtCollarStyleCombo" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
            </GridPane>
        </Tab>

        <!-- JACKET -->
        <Tab fx:id="jacketTab" text="Jacket">
            <GridPane hgap="10" vgap="8" style="-fx-padding: 10;">
                <Label text="Chest (in):" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="jacketChestField" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <Label text="Shoulder (in):" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="jacketShoulderField" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                <Label text="Length (in):" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="jacketLengthField" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                <Label text="Sleeve (in):" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="jacketSleeveField" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                <Label text="Waist (in):" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="jacketWaistField" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                <Label text="Fit:" GridPane.columnIndex="0" GridPane.rowIndex="5" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <ComboBox fx:id="jacketFitCombo" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                <Label text="Lapel:" GridPane.columnIndex="0" GridPane.rowIndex="6" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <ComboBox fx:id="jacketLapelCombo" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
            </GridPane>
        </Tab>

        <!-- SUIT -->
        <Tab fx:id="suitTab" text="Suit">
            <GridPane hgap="10" vgap="8" style="-fx-padding: 10;">
                <Label text="Jacket" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.columnSpan="2"
                       style="-fx-font-weight: bold; -fx-text-fill: -color-fg-subtle; -fx-font-size: 12px;"/>
                <Label text="Jacket Chest (in):" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="suitJacketChestField" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                <Label text="Jacket Shoulder (in):" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="suitJacketShoulderField" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                <Label text="Jacket Length (in):" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="suitJacketLengthField" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                <Label text="Jacket Sleeve (in):" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="suitJacketSleeveField" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                <Label text="Trousers" GridPane.columnIndex="0" GridPane.rowIndex="5" GridPane.columnSpan="2"
                       style="-fx-font-weight: bold; -fx-text-fill: -color-fg-subtle; -fx-font-size: 12px;"/>
                <Label text="Trouser Waist (in):" GridPane.columnIndex="0" GridPane.rowIndex="6" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="suitTrouserWaistField" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
                <Label text="Trouser Inseam (in):" GridPane.columnIndex="0" GridPane.rowIndex="7" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="suitTrouserInseamField" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="7"/>
                <Label text="Trouser Hip (in):" GridPane.columnIndex="0" GridPane.rowIndex="8" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="suitTrouserHipField" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="8"/>
                <Label text="Trouser Thigh (in):" GridPane.columnIndex="0" GridPane.rowIndex="9" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="suitTrouserThighField" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="9"/>
                <Label text="Trouser Front Rise (in):" GridPane.columnIndex="0" GridPane.rowIndex="10" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="suitTrouserFrontRiseField" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="10"/>
                <Label text="Trouser Back Rise (in):" GridPane.columnIndex="0" GridPane.rowIndex="11" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="suitTrouserBackRiseField" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="11"/>
                <Label text="Jacket Fit:" GridPane.columnIndex="0" GridPane.rowIndex="12" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <ComboBox fx:id="suitJacketFitCombo" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="12"/>
                <Label text="Lapel:" GridPane.columnIndex="0" GridPane.rowIndex="13" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <ComboBox fx:id="suitLapelCombo" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="13"/>
                <Label text="Trouser Fit Preferences:" GridPane.columnIndex="0" GridPane.rowIndex="14" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-alignment: TOP_LEFT;"/>
                <TextArea fx:id="suitTrouserFitArea" prefRowCount="2" wrapText="true"
                          GridPane.columnIndex="1" GridPane.rowIndex="14"/>
            </GridPane>
        </Tab>
    </TabPane>

    <VBox spacing="4">
        <Label text="Notes:" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
        <TextArea fx:id="notesArea" prefRowCount="2" wrapText="true"/>
    </VBox>

    <HBox spacing="10" alignment="CENTER_RIGHT"
          style="-fx-padding: 10 0 0 0; -fx-border-color: -color-border-default; -fx-border-width: 1 0 0 0;">
        <Button fx:id="saveButton" text="Save" prefWidth="100" onAction="#onSaveClick"
                style="-fx-background-color: -color-accent-emphasis; -fx-text-fill: white;"/>
        <Button fx:id="cancelButton" text="Cancel" prefWidth="100" onAction="#onCancelClick"/>
    </HBox>
</VBox>